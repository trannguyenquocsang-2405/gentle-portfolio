generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id       Int     @id @default(1)
  name     String
  avatar   String?
  greeting Json?
  about    Json?
}

model SkillCategory {
  id     Int     @id @default(autoincrement())
  name   Json    @unique
  skills Skill[]
}

model Skill {
  id         Int            @id @default(autoincrement())
  name       Json
  iconUrl    String?
  categoryId Int?
  category   SkillCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Project {
  id          Int      @id @default(autoincrement())
  title       Json
  description Json
  imageUrl    String?
  demoUrl     String?
  sourceUrl   String?
  details     Json?
  createdAt   DateTime @default(now())
}

model BlogPost {
  id        Int      @id @default(autoincrement())
  title     Json
  content   Json
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id       Int    @id @default(autoincrement())
  platform String
  url      String
  iconUrl  String?
}

model Experience {
  id          Int      @id @default(autoincrement())
  company     String
  role        Json
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean  @default(false)
  description Json?
  productUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resume {
  id        Int      @id @default(autoincrement())
  title     Json
  fileUrl   String
  createdAt DateTime @default(now())
}
